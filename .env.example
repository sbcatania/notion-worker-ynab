# YNAB Personal Access Token
# Get yours at: https://app.ynab.com/settings/developer
#
# SECURITY WARNING: This token grants FULL READ ACCESS to ALL budgets on your
# YNAB account — not just the one configured below. Treat it like a password.
# - Never commit this value to git
# - Rotate periodically (revoke old token in YNAB, create new one, update here)
# - YNAB tokens do not expire — a leaked token stays valid until manually revoked
YNAB_ACCESS_TOKEN=

# REQUIRED: Your YNAB budget ID (UUID).
# Find it in your YNAB app URL: https://app.ynab.com/<BUDGET_ID>/budget
# Example: YNAB_BUDGET_ID=f400daa1-71ad-4244-b208-60df380b7b77
YNAB_BUDGET_ID=
